generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Application {
  id      String @id @default(cuid())
  slug    String @unique
  iconUrl String

  title_en             String?
  description_en       String?
  shortDescription_en  String?

  title_es             String?
  description_es       String?
  shortDescription_es  String?

  title_ru             String?
  description_ru       String?
  shortDescription_ru  String?

  appStoreUrl   String?
  googlePlayUrl String?
  githubUrl     String?

  privacyPolicy_en String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- SETTINGS ---
model TgSettings {
  id                     Int      @id @default(1)
  vacancyBasePriceStars  Int      @default(0)
  resumeBasePriceStars   Int      @default(0)
  channelDiscountPercent Int      @default(0)
  updatedAt              DateTime @updatedAt
}

// --- TELEGRAM MODELS ---

model TgChannel {
  id         String   @id @default(cuid())
  name       String
  username   String   @unique
  category   String
  priceStars Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  orders TgOrderChannel[]
}

model TgOrder {
  id               String  @id @default(cuid())
  telegramUserId   String
  telegramUsername String?

  type String @default("VACANCY") // "VACANCY" | "RESUME" | "RANDOM_COFFEE" | "RESUME_AI"

  payload     String @default("{}")
  totalAmount Int
  status      String @default("PENDING") // PENDING, PAID_WAITING_MODERATION, PUBLISHED, REJECTED_REFUNDED, REFUNDED_BY_ADMIN, REFUNDED, etc.

  telegramPaymentChargeId String?
  paymentId               String?

  // --- NEW FIELDS FOR ADMIN / REFUNDS ---
  itemTitle       String?
  customerContact String?
  publishedLinks  String? // JSON stringified string[]
  moderatedAt     DateTime?
  refundedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channels TgOrderChannel[]
}

model TgOrderChannel {
  id        String    @id @default(cuid())
  orderId   String
  channelId String

  order   TgOrder   @relation(fields: [orderId], references: [id])
  channel TgChannel @relation(fields: [channelId], references: [id])

  @@unique([orderId, channelId])
}

// --- RANDOM COFFEE MODELS ---

model RandomCoffeeProfile {
  id             String   @id @default(cuid())
  telegramUserId String   @unique
  name           String
  specialty      String
  interests      String
  linkedin       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  participations RandomCoffeeParticipation[]
}

model RandomCoffeeParticipation {
  id        String @id @default(cuid())
  profileId String
  profile   RandomCoffeeProfile @relation(fields: [profileId], references: [id])

  status    String   @default("PAID") // PAID, MATCHED, REFUNDED, REFUNDED_BY_USER
  matchDate DateTime

  telegramPaymentChargeId String?
  createdAt DateTime @default(now())

  matchWithId String?
}

model RandomCoffeeHistory {
  id      String   @id @default(cuid())
  userAId String
  userBId String
  date    DateTime @default(now())

  @@unique([userAId, userBId])
}

model TgUserProfile {
  id             String @id @default(cuid())
  telegramUserId String @unique

  resumeOriginal  String?
  resumeCorrected String?

  updatedAt DateTime @updatedAt
}
// --- CHESS PRO WORLD CHAMPIONSHIP ---

model ChessPlayer {
  id          String   @id @default(cuid())
  publicId    String   @unique
  nickname    String
  countryCode String
  countryName String
  countryFlag String
  isActive    Boolean  @default(true)
  joinedAt    DateTime @default(now())
  leftAt      DateTime?
  totalWins   Int      @default(0)
  lastWinAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryStats       ChessPlayerCategoryStat[]
  periodCategoryStats ChessPlayerPeriodCategoryStat[]
  winEvents           ChessWinEvent[]

  @@index([countryCode])
  @@index([isActive, totalWins])
}

model ChessPlayerCategoryStat {
  id            String   @id @default(cuid())
  playerId      String
  categoryKey   String
  timeControlId String
  difficulty    String
  wins          Int      @default(0)
  bestTimeSec   Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  player ChessPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, categoryKey])
  @@index([categoryKey, wins, updatedAt])
}

model ChessCountryCategoryStat {
  id            String   @id @default(cuid())
  countryCode   String
  countryName   String
  countryFlag   String
  categoryKey   String
  timeControlId String
  difficulty    String
  wins          Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([countryCode, categoryKey])
  @@index([categoryKey, wins, updatedAt])
}

model ChessPlayerPeriodCategoryStat {
  id            String   @id @default(cuid())
  playerId      String
  periodType    String
  periodKey     String
  categoryKey   String
  timeControlId String
  difficulty    String
  wins          Int      @default(0)
  bestTimeSec   Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  player ChessPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, periodType, periodKey, categoryKey])
  @@index([periodType, periodKey, categoryKey, wins, updatedAt])
  @@index([playerId, periodType, periodKey])
}

model ChessCountryPeriodCategoryStat {
  id            String   @id @default(cuid())
  countryCode   String
  countryName   String
  countryFlag   String
  periodType    String
  periodKey     String
  categoryKey   String
  timeControlId String
  difficulty    String
  wins          Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([countryCode, periodType, periodKey, categoryKey])
  @@index([periodType, periodKey, categoryKey, wins, updatedAt])
  @@index([countryCode, periodType, periodKey])
}

model ChessWinEvent {
  id            String   @id @default(cuid())
  eventId       String   @unique
  playerId      String
  countryCode   String
  categoryKey   String
  timeControlId String
  difficulty    String
  elapsedSec    Int?
  occurredAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  player ChessPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, createdAt])
  @@index([categoryKey, createdAt])
  @@index([countryCode, categoryKey])
}
